<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Password | VaultX</title>

    <link rel="stylesheet" href="/css/add.css">
    <link rel="stylesheet" href="/css/navbar.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>

<body>

    <%- include("partials/navbar") %>

        <div class="container">

            <div class="card">

                <h1>
                    <i class="fa-solid fa-plus"></i>
                    Add New Password
                </h1>

                <form action="/add/submit" method="POST">

                    <!-- App Name -->

                    <div class="form-group">
                        <label>Application / Website Name</label>

                        <input type="text" name="app_name" placeholder="Github, Gmail, Netflix..." required>
                    </div>

                    <!-- Category -->

                    <div class="form-group">
                        <label>Category</label>

                        <select name="category">

                            <option value="Website">Website</option>
                            <option value="Application">Application</option>
                            <option value="Social_Media">Social Media</option>
                            <option value="Banking">Banking</option>
                            <option value="Work">Work</option>
                            <option value="Other">Other</option>

                        </select>
                    </div>

                    <!-- Username -->

                    <div class="form-group">
                        <label>Username / Email</label>

                        <input type="text" name="username" placeholder="Enter username or email" required>
                    </div>

                    <!-- Password -->

                    <div class="form-group">

                        <label>Password</label>

                        <div class="password-box">

                            <input type="password" id="password" name="password" placeholder="Enter Password" required>

                            <i id="togglePassword" class="fa-solid fa-eye">
                            </i>

                        </div>

                    </div>

                    <!-- Buttons -->

                    <div class="btn-group">

                        <button type="button" id="generateBtn" class="generate-btn">

                            Generate Password

                        </button>

                    </div>

                    <!-- Notes -->

                    <div class="form-group">

                        <label>Notes</label>

                        <textarea name="notes" rows="4" placeholder="Add notes here...">
                    </textarea>

                    </div>

                    <!-- Favorite -->

                    <div class="checkbox-group">

                        <input type="checkbox" id="favorite" name="favorite">

                        <label for="favorite">
                            Mark as Favorite ⭐
                        </label>

                    </div>

                    <!-- Submit -->

                    <button type="submit" class="save-btn">

                        Save Password

                    </button>

                </form>

            </div>

        </div>

        <script>

            const passwordInput =
                document.getElementById("password");

            const togglePassword =
                document.getElementById("togglePassword");

            togglePassword.addEventListener("click", () => {

                if (passwordInput.type === "password") {

                    passwordInput.type = "text";

                    togglePassword.classList.remove("fa-eye");
                    togglePassword.classList.add("fa-eye-slash");

                }
                else {

                    passwordInput.type = "password";

                    togglePassword.classList.remove("fa-eye-slash");
                    togglePassword.classList.add("fa-eye");

                }

            });


            // Generate Password

            document
                .getElementById("generateBtn")
                .addEventListener("click", () => {

                    const chars =
                        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*";

                    let password = "";

                    for (let i = 0; i < 14; i++) {

                        password += chars.charAt(
                            Math.floor(Math.random() * chars.length)
                        );

                    }

                    passwordInput.value = password;

                });

        </script>

</body>

</html>