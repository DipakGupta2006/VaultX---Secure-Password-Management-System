<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VaultX - Saved Passwords</title>

    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/deletes.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="icon" type="image/png" href="/images/logo.png">


    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>

<body>

    <%- include("partials/navbar") %>

        <div class="container">

            <div class="header">

                <h1>
                    <i class="fa-solid fa-lock"></i>
                    Saved Passwords
                </h1>

                <a href="/add" class="add-btn">
                    <i class="fa-solid fa-plus"></i>
                    Add Passwords
                </a>

            </div>


            <% if(passwords.length===0){ %>

                <div class="empty-state">

                    <i class="fa-solid fa-folder-open"></i>

                    <h2>No Passwords Found To Delete</h2>

                    <p>Add your first password to vaultX.</p>

                </div>

                <% } else { %>

                    <div class="table-container">

                        <table>

                            <thead>

                                <tr>
                                    <th>ID</th>
                                    <th>App/Web Name</th>
                                    <th>Category</th>
                                    <th>Username</th>
                                    <th>Password</th>
                                    <th>Notes</th>
                                    <th>Favorite</th>
                                    <!-- <th>Actions</th> -->
                                </tr>

                            </thead>

                            <tbody>

                                <% passwords.forEach(password=> { %>

                                    <tr>

                                        <td>
                                            <%= password.id %>
                                        </td>

                                        <td>
                                            <%= password.app_name %>
                                        </td>

                                        <td>
                                            <%= password.category %>
                                        </td>

                                        <td>
                                            <%= password.username %>
                                        </td>

                                        <td>

                                            <span class="password-text" data-password="<%= password.password %>">

                                                ********

                                            </span>

                                            <button class="show-btn">

                                                <i class="fa-solid fa-eye"></i>

                                            </button>

                                        </td>

                                        <td class="notes-column">

                                            <% if(password.notes){ %>

                                                <%= password.notes %>

                                                    <% } else { %>

                                                        -

                                                        <% } %>

                                        </td>


                                        <td>


                                            <% if(password.favorite){ %>

                                                ⭐

                                                <% } else { %>

                                                    -

                                                    <% } %>

                                        </td>

                                        <!-- <td>

                                            <a href="/edit/<%= password.id %>" class="edit-btn">

                                                <i class="fa-solid fa-pen"></i>

                                            </a>

                                            <a href="/delete/<%= password.id %>" class="delete-btn">

                                                <i class="fa-solid fa-trash"></i>

                                            </a>

                                        </td> -->

                                    </tr>

                                    <% }) %>

                            </tbody>

                        </table>

                    </div>

                    <% } %>

                        <div class="formContainer">

                            <form action="/deletes/delete-password" method="POST">
                                <label for="ID">Enter ID To Delete:</label>
                                <input type="number" id="ID" name="id" autofocus required>
                                <br><br>

                                <button type="submit">Delete Password</button>
                            </form>
                        </div>

        </div>

        <%- include("partials/footer") %>


            <script>

                const buttons =
                    document.querySelectorAll(".show-btn");

                buttons.forEach(button => {

                    button.addEventListener("click", () => {

                        const span =
                            button.parentElement.querySelector(".password-text");

                        if (span.innerText === "********") {

                            span.innerText =
                                span.dataset.password;

                            button.innerHTML =
                                '<i class="fa-solid fa-eye-slash"></i>';

                        }
                        else {

                            span.innerText = "********";

                            button.innerHTML =
                                '<i class="fa-solid fa-eye"></i>';

                        }

                    });

                });

                const form = document.getElementById("passwordForm");

                form.addEventListener("submit", function () {

                    setTimeout(() => {

                        form.reset();

                    }, 100);

                });


            </script>

</body>

</html>